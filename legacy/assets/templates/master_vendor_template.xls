<html>
<head>
  <meta charset="UTF-8">
  <title>Master Vendor Template</title>
  <style>
    table { border-collapse: collapse; font-family: Arial, sans-serif; font-size: 11pt; }
    th, td { border: 1px solid #000; padding: 6px 8px; }
    th { background: #f2f2f2; }
  </style>
</head>
<body>
  <table>
    <tr>
      <th>code</th>
      <th>name</th>
      <th>address</th>
      <th>phone</th>
      <th>email</th>
      <th>contact_person</th>
      <th>bank_name</th>
      <th>bank_number</th>
    </tr>
    <tr>
      <td>VD-001</td>
      <td>PT. Supplier Maju</td>
      <td>Jl. Vendor No. 10, Jakarta</td>
      <td>021-888888</td>
      <td>sales@suppliermaju.co.id</td>
      <td>Budi</td>
      <td>BCA</td>
      <td>1234567890</td>
    </tr>
    <tr>
      <td>VD-002</td>
      <td>CV. Sumber Makmur</td>
      <td>Jl. Makmur No. 5, Bandung</td>
      <td>022-777777</td>
      <td>info@sumbermakmur.co.id</td>
      <td>Sari</td>
      <td>Mandiri</td>
      <td>0987654321</td>
    </tr>
  </table>
</body>
</html>
